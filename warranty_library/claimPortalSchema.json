          "fields": [
            { "key": "scan_tool_test_code_1", "label": "Scan Tool Test Code 1", "type": "string", "required": false },
            { "key": "scan_tool_test_code_2", "label": "Scan Tool Test Code 2", "type": "string", "required": false },
