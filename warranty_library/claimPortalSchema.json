          "fields": [
            { "key": "line", "label": "Line", "type": "number", "required": true },
            { "key": "part_number", "label": "Part Number", "type": "string", "required": false },
            { "key": "part_description", "label": "Part Description", "type": "string", "required": false },
            { "key": "part_quantity", "label": "Part Quantity", "type": "number", "required": false },
            { "key": "part_dollars", "label": "Part Dollars", "type": "currency", "required": false }
          ]
        },
        "attachments": {
          "label": "Attachments",
          "max_file_size_mb": 20,
          "fields": [
            { "key": "upload_by", "label": "Upload By", "type": "string", "required": false },
            { "key": "file_type", "label": "Type", "type": "string", "required": false },
            { "key": "attachment_name", "label": "Attachment Name", "type": "string", "required": false },
            { "key": "category", "label": "Category", "type": "string", "required": false }
          ],
          "allowed_categories": [
            "VIN",
            "Odometer/Mileage",
            "Part",
            "Other Attachment",
            "Repair Order",
            "Customer DMV Registration",
            "Sublet Invoice",
            "Original Owner Affidavit",
            "Oil Dipstick Photo",
            "Transmission Diagnostic Worksheet"
          ],
          "system_generated_examples": [
            "VIN Verified by STUI",
            "Mileage Verified by STUI"
          ]
        },
