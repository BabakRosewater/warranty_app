    "resubmit": {
      "screen_name": "Warranty Claim ReSubmit",
      "sections": {
        "header_status": {
          "fields": [
            { "key": "ro_number", "label": "R.O. #", "type": "string" },
            { "key": "hma_claim_number", "label": "HMA Claim #", "type": "string" },
            { "key": "dms_claim_number", "label": "DMS Claim #", "type": "string" },
            { "key": "claim_type", "label": "Claim Type", "type": "string" },
            { "key": "vin", "label": "VIN #", "type": "string" },
            { "key": "ro_date", "label": "R.O. Date", "type": "date" },
            { "key": "adjustment_date", "label": "Adjustment Date", "type": "date" },
            { "key": "status", "label": "Status", "type": "string" }
          ]
        },
        "return_reason": {
          "fields": [
            { "key": "return_code", "label": "Return Code", "type": "string" },
            { "key": "return_message", "label": "Return Message", "type": "string" }
          ]
        },
        "remark_history": {
          "repeatable": true,
          "fields": [
            { "key": "remark_type", "label": "Type", "type": "string" },
            { "key": "user_id", "label": "UserID", "type": "string" },
            { "key": "date", "label": "Date", "type": "date" },
            { "key": "remark", "label": "Remark", "type": "text" }
          ]
