          "restricted_characters_note": "Please do not use the characters \" ~ ` ! @ # $ % & * ( ) [ ] { } | : ; ' < > / + - in the following fields.",
          "fields": [
            { "key": "complaint_description", "label": "Complaint Description", "type": "text", "required": true },
            { "key": "cause_description", "label": "Cause Description", "type": "text", "required": true },
            { "key": "correction_description", "label": "Correction Description", "type": "text", "required": true },
            { "key": "additional_comments", "label": "Additional Comments", "type": "text", "required": false },
            { "key": "dealer_pwa_reply", "label": "Dealer PWA Reply", "type": "text", "required": false }
          ]
        },
        "summary": {
          "label": "Summary",
          "fields": [
            { "key": "net_parts_total", "label": "Net Parts Total", "type": "currency" },
            { "key": "towing", "label": "Towing", "type": "currency" },
            { "key": "mark_up_percent", "label": "Mark Up Percent", "type": "percentage" },
            { "key": "total_labor_amount", "label": "Total Labor Amount", "type": "currency" },
            { "key": "mark_up_dollar", "label": "Mark Up Dollar", "type": "currency" },
            { "key": "claim_total", "label": "Claim Total", "type": "currency" },
            { "key": "part_total", "label": "Part Total", "type": "currency" },
            { "key": "hma_pay_percent", "label": "HMA Pay Percent", "type": "percentage" },
            { "key": "sublet_amount", "label": "Sublet Amount", "type": "currency" },
            { "key": "adjusted_claim", "label": "Adjusted Claim", "type": "currency" }
          ]
        }
